  "keyFeatures": [
    "Clean Architecture with clear separation of concerns",
    "CQRS pattern with MediatR for command/query separation",
    "JWT authentication with refresh tokens and 2FA support",
    "Role-Based Access Control (RBAC) with granular permissions",
    "Advanced security features (IP blocking, audit logs, login attempts)",
    "Entity Framework Core 8 with SQL Server support",
    "FluentValidation for centralized validation logic",
    "Comprehensive testing suite (unit, functional, integration)",
    "OpenAPI/Swagger documentation with NSwag",
    "Health checks and monitoring endpoints"
  ],
  "publicApiSurface": [
    "POST /authentication/register - Register new user",
    "POST /authentication/login - User login",
    "POST /authentication/logout - User logout",
    "POST /authentication/refresh-token - Refresh JWT token",
    "POST /authentication/verify-2fa - Verify two-factor authentication",
    "POST /authentication/forgot-password - Initiate password reset",
    "POST /authentication/reset-password - Reset password",
    "POST /authentication/enable-2fa - Enable two-factor authentication",
    "GET /authentication/audit-logs - Get all audit logs",
    "GET /authentication/audit-logs/user/{userId} - Get user audit logs",
    "POST /roles/create - Create new role",
    "POST /roles/assign - Assign role to user",
    "GET /roles - Get all roles",
    "POST /permissions/create - Create permission",
    "POST /permissions/assign - Assign permission to role",
    "GET /permissions - Get all permissions",
    "GET /security/health - Health check endpoint"
  ]
}
